def remove_vowels(document):
    vowels = "aeiouyAEIOUY"
    result_string = ""
    for char in document:
        if char not in vowels:
            result_string += char
    return result_string

print(remove_vowels("This is a test document."))

def make_stickers(details_count, robot_part):
    stickers = []
    if details_count == 0:
        return stickers
    else:
        for n in range(1, details_count + 1):
            stickers.append(f"{robot_part} detail #{n}")
    return stickers

    

import math


def get_plan(current_production, months, percent):
    plan_per_mounth = math.floor([])
    while len(plan_per_mounth) < months:
        result = current_production + (current_production * percent) / 100 #130
        plan_per_mounth.append(result)
        current_production = result
    return 
        

